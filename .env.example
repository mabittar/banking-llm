# ===========================================
# LangChain Pix Environment - Configuração
# ===========================================

# Ambiente (local | development)
ENVIRONMENT=local

# ----- LLM - OpenRouter (produção) -----
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash

# ----- LLM - Ollama (desenvolvimento local) -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:latest

# ----- Guardrail -----
GUARDRAIL_ENABLED=true
GUARDRAIL_MODEL=meta-llama/llama-guard-4-12b
GUARDRAIL_THRESHOLD=0.7

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=null

# ----- PostgreSQL -----
DBNAME=banking-llm
DB_USER=postgres
DB_PASSWORD=mysecretpassword
DB_HOST=localhost
DB_PORT=5433

# ----- Banking API -----
CLIENT_ID=client
REALM_NAME=tech
BANKING_BASE_URL=
JWT_SECRET=your-jwt-secret-here
FIN_ACCOUNT_ID=your-fin-account-id-here
FIN_ACCOUNT_ID_FALLBACK=your-fallback-account-id-here
TRANSACTION_HASH_SECRET=your-fin-account-transaction-hash-secret-key-here