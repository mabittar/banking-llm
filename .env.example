# OpenRouter API key – get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use via OpenRouter (see https://openrouter.ai/models)
OPENROUTER_MODEL=google/gemini-2.5-flash


# Guardrail
GUARDRAIL_ENABLED=true
GUARDRAIL_MODEL="llama-guard3:8b"

#Cache
REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379

# Database
DBNAME=banking-llm
DB_USER=postgres
DB_PASSWORD=mysecretpassword
DB_HOST=localhost
DB_PORT=5432

# Banking
CLIENT_ID="tech-hub-client"
REALM_NAME="tech-hub"
JWT_SECRET="your-jwt-secret-here"
FIN_ACCOUNT_ID="your-fin-account-id-here"
FIN_ACCOUNT_ID_FALLBACK="your-fallback-account-id-here"
TRANSACTION_HASH_SECRET="your-fin-account-transaction-hash-secret-key-here"